# General
ENV=development
# CORS (comma-separated origins; default: http://localhost:4000, http://127.0.0.1:4000)
# CORS_ORIGIN=http://localhost:4000,http://localhost:5173
HOST=0.0.0.0
PORT=3000

# Database (use ligamatch_development to avoid interfering with other projects)
DATABASE_HOST=postgresql://postgres@127.0.0.1
DATABASE_NAME=ligamatch_development
DATABASE_URL=postgres://postgres@127.0.0.1:5432/ligamatch_development

# JWT (change in production)
JWT_SECRET=change-this-secret-in-production

# Password reset link base URL (e.g. https://app.ligamatch.com or http://localhost:4000)
# APP_URL=http://localhost:4000

# OpenAI (player document autofill from ID / birth certificate)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
